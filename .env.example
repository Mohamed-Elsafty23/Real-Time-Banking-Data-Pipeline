# Copy to .env at repo root for docker-compose variable substitution where used.
POSTGRES_USER=banking
POSTGRES_PASSWORD=change_me
POSTGRES_DB=banking

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me

AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me
AIRFLOW_DB_NAME=airflow
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=change_me

# Optional: comma-separated raw tables for bronze DAG (defaults: customers,accounts,transactions)
# RAW_TABLE_LIST=customers,accounts,transactions

# Optional: Kafka Connect REST URL when posting the Debezium connector from the host
# KAFKA_CONNECT_URL=http://localhost:8083
